<%- include('_head', { titre: defi ? 'Modifier un défi' : 'Nouveau défi' }) %>
<%- include('_nav', { actif: 'defis' }) %>
<main class="page-admin">
  <h1><%= defi ? 'Modifier le défi' : 'Nouveau défi' %></h1>
  <form class="form" method="post" enctype="multipart/form-data" action="<%= defi ? '/admin/defis/' + defi.id : '/admin/defis' %>">
    <label>Titre
      <input name="titre" required value="<%= defi ? defi.titre : '' %>">
    </label>
    <label>Émoji <span class="muted">(affiché côté participant, ex. 🔍 ⛪ 🚴)</span>
      <input name="emoji" maxlength="8" value="<%= defi && defi.emoji ? defi.emoji : '' %>" style="max-width:120px; font-size:1.4rem; text-align:center">
    </label>
    <label>Consigne / description
      <textarea name="description" rows="3"><%= defi ? defi.description : '' %></textarea>
    </label>
    <label>Image de la consigne <span class="muted">(optionnelle, montrée aux participants sous la consigne)</span>
      <input type="file" name="image_consigne" accept="image/*">
    </label>
    <% if (defi && defi.image_consigne) { %>
      <div class="form-row" style="align-items:center; gap:12px;">
        <img src="/uploads/<%= defi.image_consigne %>" alt="image de consigne actuelle" style="max-width:160px; border-radius:8px; border:1px solid var(--bord)">
        <label class="switch"><input type="checkbox" name="supprimer_image" value="1"> Retirer cette image</label>
      </div>
    <% } %>
    <%
      // Valeur unique « type de réponse » dérivée de (type, media) en base.
      let typeReponse = 'photo';
      if (defi) {
        if (defi.type === 'texte') typeReponse = 'texte';
        else if (defi.type === 'mixte') typeReponse = defi.media === 'video' ? 'video_texte' : (defi.media === 'photo_video' ? 'photo_video_texte' : 'photo_texte');
        else typeReponse = defi.media === 'video' ? 'video' : (defi.media === 'photo_video' ? 'photo_video' : 'photo');
      }
      const optionsTR = [['photo', 'Photo'], ['video', 'Vidéo (clip court)'], ['photo_video', 'Photo ou vidéo'], ['texte', 'Texte'], ['photo_texte', 'Photo + texte'], ['video_texte', 'Vidéo + texte'], ['photo_video_texte', 'Photo ou vidéo + texte']];
    %>
    <label>Type de réponse <span class="muted">(ce que le binôme envoie)</span>
      <select name="type_reponse">
        <% optionsTR.forEach(([v, lab]) => { %><option value="<%= v %>" <%= typeReponse === v ? 'selected' : '' %>><%= lab %></option><% }) %>
      </select>
    </label>
    <label>Disponibilité
      <select name="disponibilite">
        <% ['weekend', 'J1', 'J2'].forEach((t) => { %><option value="<%= t %>" <%= defi && defi.disponibilite === t ? 'selected' : '' %>><%= t %></option><% }) %>
      </select>
    </label>
    <label class="switch"><input type="checkbox" name="multi_photos" value="1" <%= defi && defi.multi_photos ? 'checked' : '' %>> <strong>Plusieurs photos</strong> <span class="muted">(le participant peut en envoyer jusqu'à 10 — ex. « 5 églises »)</span></label>
    <label>Réponse « choix de binômes » <span class="muted">(nombre de menus à choisir ; 0 = désactivé ; remplace photo/texte — ex. « Le conseil » = 3)</span>
      <input type="number" name="nb_choix_binomes" min="0" max="8" value="<%= defi && defi.nb_choix_binomes ? defi.nb_choix_binomes : 0 %>" style="max-width:120px">
    </label>
    <% if (defi && defi.nb_choix_binomes > 0) { %>
      <p style="margin:0"><a class="btn-mini" href="/admin/defis/<%= defi.id %>/votes">📊 Voir le classement des votes</a></p>
    <% } %>
    <label class="switch"><input type="checkbox" name="bonus" value="1" <%= defi && defi.bonus ? 'checked' : '' %>> Défi <strong>bonus</strong> <span class="muted">(affiché en doré, secondaire)</span></label>
    <label class="switch"><input type="checkbox" name="live" value="1" <%= defi && defi.live ? 'checked' : '' %>> <strong>Épreuve en direct</strong> <span class="muted">(non soumettable par les participants ; points attribués à la main)</span></label>
    <% if (defi && defi.live) { %>
      <p style="margin:0"><a class="btn-mini" href="/admin/defis/<%= defi.id %>/points">⚡ Attribuer les points en direct</a></p>
    <% } %>
    <label>Mode de validation
      <select name="mode_validation">
        <% ['manuel', 'auto', 'ia'].forEach((t) => { %><option value="<%= t %>" <%= defi && defi.mode_validation === t ? 'selected' : '' %>><%= t %></option><% }) %>
      </select>
    </label>
    <p class="aide-modes">
      <strong>manuel</strong> — tu valides ou refuses chaque soumission à la main. À choisir par défaut, pour la grande majorité des défis (photos à juger, défis sur le terrain).<br>
      <strong>auto</strong> — la réponse du binôme est comparée automatiquement à la <em>« réponse attendue »</em> ci-dessous. Réserve-le aux énigmes à réponse exacte et connue (un mot, un nombre).<br>
      <strong>ia</strong> — l'IA pré-trie les photos selon le <em>« critère IA »</em> ci-dessous (bon / incertain / mauvais) pour te faire gagner du temps, mais tu gardes toujours le dernier mot. Utile s'il y a beaucoup de photos similaires à filtrer.
    </p>
    <label>Réponse attendue <span class="muted">(mode auto)</span>
      <input name="reponse_attendue" value="<%= defi && defi.reponse_attendue ? defi.reponse_attendue : '' %>">
    </label>
    <label>Critère IA <span class="muted">(mode ia)</span>
      <textarea name="critere_ia" rows="2" placeholder="ex. Une borne kilométrique routière est visible sur la photo"><%= defi && defi.critere_ia ? defi.critere_ia : '' %></textarea>
    </label>
    <label>Points max
      <input type="number" name="points_max" min="0" value="<%= defi ? defi.points_max : 10 %>">
    </label>
    <label>Ordre dans le jour <span class="muted">(1, 2, 3… recommence à chaque catégorie ; laisser vide = à la fin)</span>
      <input type="number" name="ordre" min="1" value="<%= defi && defi.ordre ? defi.ordre : '' %>">
    </label>
    <div class="form-row">
      <button class="btn" type="submit">Enregistrer</button>
      <a class="lien" href="/admin/defis">Annuler</a>
    </div>
  </form>
</main>
<%- include('_foot') %>
