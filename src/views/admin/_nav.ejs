  <nav class="nav-admin">
    <a href="/admin/revue" class="<%= actif === 'revue' ? 'on' : '' %>">Soumissions</a>
    <a href="/admin/defis" class="<%= actif === 'defis' ? 'on' : '' %>">Défis</a>
    <a href="/admin/binomes" class="<%= actif === 'binomes' ? 'on' : '' %>">Binômes</a>
