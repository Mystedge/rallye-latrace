<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#34765e">
  <title>Mes défis — Rallye La Trace</title>
  <link rel="manifest" href="/manifest.webmanifest">
  <link rel="icon" type="image/svg+xml" href="/logo-vert.svg">
  <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png">
  <link rel="apple-touch-icon" href="/icon-180.png">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <header class="barre">
    <strong class="barre-titre"><img class="barre-logo" src="/logo-latrace.svg" alt="La Trace"> <span class="barre-nom"><%= binome.nom %></span></strong>
    <div class="barre-actions">
      <span class="score-pill" title="Total de tes points validés">🏆 <%= score %> pts</span>
      <form method="post" action="/api/logout">
        <button class="btn-deco" type="submit" aria-label="Se déconnecter" title="Se déconnecter">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
            <polyline points="16 17 21 12 16 7"/>
            <line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
        </button>
      </form>
    </div>
  </header>

  <main class="page">
    <div id="banniere-attente" class="banniere" hidden></div>

    <%
      function metaDefi(e, d) {
        if (!e) return { cls: '', pill: '', txt: d.points_max + ' pts' };
        if (e.statut === 'valide') return { cls: 'etat-valide', pill: 'sp-valide', txt: 'Validé' + (e.points != null ? ' · ' + e.points + ' pts' : '') };
        if (e.statut === 'refuse') return { cls: 'etat-refuse', pill: 'sp-refuse', txt: 'Erroné' };
        return { cls: 'etat-soumis', pill: 'sp-soumis', txt: 'Envoyé' };
      }
      const countValide = (arr) => arr.filter((d) => etat[d.id] && etat[d.id].statut === 'valide').length;
      const aJour = groupes.jour.length > 0;
      const aWeekend = groupes.weekend.length > 0;
    %>

    <% if (aJour || aWeekend) { %>
      <div class="barre-nav">
        <input id="recherche" class="recherche" type="search" inputmode="search" autocomplete="off" placeholder="🔍 Rechercher un défi…" aria-label="Rechercher un défi">
        <% if (aJour && aWeekend) { %>
          <nav class="onglets" role="tablist">
            <button class="onglet" type="button" data-cible="jour">Aujourd'hui <span class="onglet-compte"><%= countValide(groupes.jour) %>/<%= groupes.jour.length %></span></button>
            <button class="onglet" type="button" data-cible="weekend">Week-end <span class="onglet-compte"><%= countValide(groupes.weekend) %>/<%= groupes.weekend.length %></span></button>
          </nav>
        <% } %>
      </div>
    <% } %>

    <% if (aJour) { %>
      <section class="groupe" data-groupe="jour">
        <h2>Défis du jour (<%= jour %>)</h2>
        <ul class="defis">
          <% groupes.jour.forEach((d) => { const m = metaDefi(etat[d.id], d); const bonus = !!d.bonus; %>
            <li>
              <a class="defi <%= m.cls %> <%= bonus ? 'defi-bonus' : '' %>" href="/defi/<%= d.id %>" data-recherche="<%= d.titre %> <%= d.description || '' %>">
                <span class="defi-emoji"><%= d.emoji || '📍' %></span>
                <span class="defi-corps">
                  <% if (bonus) { %><span class="tag-bonus">Bonus</span><% } %>
                  <span class="defi-titre"><%= d.titre %></span>
                </span>
                <% if (m.pill) { %><span class="statut-pill <%= m.pill %>"><%= m.txt %></span><% } else { %><span class="defi-meta"><%= m.txt %></span><% } %>
              </a>
            </li>
          <% }) %>
        </ul>
      </section>
    <% } %>

    <% if (aWeekend) { %>
      <section class="groupe" data-groupe="weekend">
        <h2>Défis week-end</h2>
        <ul class="defis">
          <% groupes.weekend.forEach((d) => { const m = metaDefi(etat[d.id], d); const bonus = !!d.bonus; %>
            <li>
              <a class="defi <%= m.cls %> <%= bonus ? 'defi-bonus' : '' %>" href="/defi/<%= d.id %>" data-recherche="<%= d.titre %> <%= d.description || '' %>">
                <span class="defi-emoji"><%= d.emoji || '📍' %></span>
                <span class="defi-corps">
                  <% if (bonus) { %><span class="tag-bonus">Bonus</span><% } %>
                  <span class="defi-titre"><%= d.titre %></span>
                </span>
                <% if (m.pill) { %><span class="statut-pill <%= m.pill %>"><%= m.txt %></span><% } else { %><span class="defi-meta"><%= m.txt %></span><% } %>
              </a>
            </li>
          <% }) %>
        </ul>
      </section>
    <% } %>

    <% if (!aJour && !aWeekend) { %>
      <p class="vide">Aucun défi disponible pour le moment.</p>
    <% } %>
    <p id="recherche-vide" class="vide" hidden>Aucun défi ne correspond à ta recherche.</p>
  </main>

  <script src="/app.js"></script>
</body>
</html>
