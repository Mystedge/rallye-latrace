<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#34765e">
  <title>Classement — Rallye La Trace</title>
  <link rel="manifest" href="/manifest.webmanifest">
  <link rel="icon" type="image/svg+xml" href="/logo-vert.svg">
  <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png">
  <link rel="apple-touch-icon" href="/icon-180.png">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <header class="barre">
    <a class="lien" href="/accueil">← Retour</a>
    <img class="barre-logo" src="/logo-latrace.svg" alt="La Trace">
  </header>

  <main class="page">
    <h1 class="titre-defi">🏆 Classement</h1>
    <ol class="classement">
      <% lignes.forEach((l, i) => { const medaille = ['🥇', '🥈', '🥉'][i] || ''; %>
        <li class="rang <%= l.id === binomeId ? 'rang-moi' : '' %>">
          <span class="rang-pos"><%= medaille || (i + 1) %></span>
          <span class="rang-nom"><%= l.nom %><% if (l.id === binomeId) { %> <span class="muted">(toi)</span><% } %></span>
          <span class="rang-pts"><%= l.total %> pts</span>
        </li>
      <% }) %>
    </ol>
    <% if (!lignes.length) { %><p class="vide">Pas encore de points attribués.</p><% } %>
  </main>
</body>
</html>
