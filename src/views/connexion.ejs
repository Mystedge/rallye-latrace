<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#34765e">
  <title>Rallye La Trace 2026</title>
  <link rel="manifest" href="/manifest.webmanifest">
  <link rel="icon" type="image/svg+xml" href="/logo-vert.svg">
  <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png">
  <link rel="apple-touch-icon" href="/icon-180.png">
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="centre">
  <main class="carte">
    <img class="logo-connexion" src="/logo-vert.svg" alt="La Trace" width="96" height="132">
    <h1>La Trace</h1>
    <p class="sous-titre">Rallye 2026 · entre le code de ton binôme pour commencer.</p>
    <% if (erreur) { %><p class="erreur"><%= erreur %></p><% } %>
    <form method="post" action="/api/login" class="form">
      <label for="code">Code du binôme</label>
      <input id="code" name="code" type="text" inputmode="text" autocapitalize="characters"
             autocomplete="off" required autofocus placeholder="ex. K7F3QM">
      <button type="submit" class="btn">Entrer</button>
    </form>
  </main>
</body>
</html>
