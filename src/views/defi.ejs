<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#34765e">
  <title><%= defi.titre %> — Rallye La Trace</title>
  <link rel="manifest" href="/manifest.webmanifest">
  <link rel="icon" type="image/svg+xml" href="/logo-vert.svg">
  <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png">
  <link rel="apple-touch-icon" href="/icon-180.png">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <header class="barre">
    <a class="lien" href="/accueil">← Retour</a>
    <img class="barre-logo" src="/logo-latrace.svg" alt="La Trace">
  </header>

  <main class="page">
    <% if (defi.bonus) { %><p class="ligne-bonus"><span class="tag-bonus">Défi bonus</span></p><% } %>
    <h1 class="titre-defi"><% if (defi.emoji) { %><span class="titre-emoji"><%= defi.emoji %></span> <% } %><%= defi.titre %></h1>
    <% if (defi.description) { %><p class="consigne"><%= defi.description %></p><% } %>
    <% if (defi.image_consigne) { %><img class="consigne-img" src="/uploads/<%= defi.image_consigne %>" alt="illustration du défi" loading="lazy"><% } %>

    <% if (soumission) { %>
      <% if (soumission.statut === 'valide') { %>
        <p class="statut-bloc sb-valide">✅ Réponse validée<%= soumission.points_attribues != null ? ' — ' + soumission.points_attribues + ' pts' : '' %></p>
      <% } else if (soumission.statut === 'refuse') { %>
        <p class="statut-bloc sb-refuse">❌ Réponse erronée — tu peux en renvoyer une nouvelle.</p>
      <% } else { %>
        <p class="statut-bloc sb-soumis">⏳ Réponse envoyée — en attente de validation par l'organisation.</p>
      <% } %>
    <% } %>

    <% if (defi.live) { %>
      <p class="statut-bloc sb-soumis">⚡ Épreuve en direct — les points sont attribués par l'organisation, rien à envoyer ici.</p>
    <% } else { %>
    <form id="form-defi" class="form" data-defi-id="<%= defi.id %>" data-type="<%= defi.type %>" data-media="<%= defi.media || 'photo' %>">
      <% if (defi.type === 'texte' || defi.type === 'mixte') { %>
        <label for="texte">Ta réponse</label>
        <textarea id="texte" name="texte" rows="4" placeholder="Écris ta réponse…"><%= soumission && soumission.texte ? soumission.texte : '' %></textarea>
      <% } %>

      <% if (defi.type === 'photo' || defi.type === 'mixte') {
           const m = defi.media || 'photo';
           const multi = !!defi.multi_photos;
           const acceptVal = m === 'video' ? 'video/*' : (m === 'photo_video' ? 'image/*,video/*' : 'image/*');
           const labelMedia = (m === 'video' ? 'Vidéo' : (m === 'photo_video' ? 'Photo ou vidéo' : 'Photo')) + (multi ? 's' : '');
           const estVid = (p) => /\.(mp4|mov|webm|m4v|3gp)$/i.test(p || '');
           let dejaMedias = [];
           if (soumission && soumission.photos) { try { dejaMedias = JSON.parse(soumission.photos); } catch (e) { dejaMedias = []; } }
           else if (soumission && soumission.photo_path) { dejaMedias = [{ p: soumission.photo_path, t: soumission.thumb_path }]; }
      %>
        <label for="photo"><%= labelMedia %></label>
        <% if (dejaMedias.length) { %>
          <p class="muted"><%= dejaMedias.length > 1 ? dejaMedias.length + ' fichiers déjà envoyés :' : 'Déjà envoyé :' %></p>
          <div class="apercus">
            <% dejaMedias.forEach((md) => { %>
              <% if (estVid(md.p)) { %>
                <video class="apercu" src="/uploads/<%= md.p %>" controls preload="metadata"></video>
              <% } else { %>
                <img class="apercu" src="/uploads/<%= md.t || md.p %>" alt="fichier précédent">
              <% } %>
            <% }) %>
          </div>
          <p class="muted">Choisis <%= multi ? 'de nouveaux fichiers' : 'un nouveau fichier' %> pour remplacer.</p>
        <% } %>
        <input id="photo" name="photo" type="file" accept="<%= acceptVal %>"<%= multi ? ' multiple' : '' %>>
        <% if (multi) { %><p class="muted">Tu peux sélectionner plusieurs photos d'un coup (jusqu'à 10).</p><% } %>
        <% if (m !== 'photo') { %><p class="muted">Vidéo : environ 1 min, 150 Mo max.</p><% } %>
        <div id="apercu-conteneur" class="apercus"></div>
      <% } %>

      <p id="etat-envoi" class="etat" role="status" aria-live="polite"></p>
      <button type="submit" class="btn" id="btn-envoyer">Envoyer</button>

      <% if (defi.media === 'video' || defi.media === 'photo_video') { %>
        <div class="whatsapp-bloc">
          <p>Souci pour envoyer la vidéo (réseau, fichier trop lourd) ? Envoie-la à <strong>Tristan&nbsp;— 06&nbsp;50&nbsp;23&nbsp;00&nbsp;26</strong> sur WhatsApp, puis signale-le ici.</p>
          <button type="button" class="btn-whatsapp" id="btn-whatsapp">J'ai envoyé par WhatsApp</button>
        </div>
      <% } %>
    </form>
    <% } %>
  </main>

  <script src="/vendor/browser-image-compression.js"></script>
  <script src="/vendor/heic2any.min.js"></script>
  <script src="/app.js"></script>
</body>
</html>
