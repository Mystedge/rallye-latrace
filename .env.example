# Serveur
PORT=3000
SESSION_SECRET=change-moi-en-secret-aleatoire

# Base de données / fichiers (chemins relatifs à la racine du projet)
DB_PATH=./data/rallye.db
UPLOADS_DIR=./uploads

# Admin
ADMIN_PASSWORD=change-moi

# IA — pré-qualification des photos (Epic 3)
ANTHROPIC_API_KEY=

# Sauvegarde (Epic 5)
BACKUP_DIR=./backup

# Sauvegarde hors-VPS vers Google Drive (conteneur rclone du docker-compose).
# RCLONE_DRIVE_TOKEN = le jeton JSON renvoyé par `rclone authorize "drive"` (cf. docs/MAINTENANCE.md).
# Laisser vide désactive proprement la sauvegarde Drive.
RCLONE_DRIVE_TOKEN=
RCLONE_DRIVE_DOSSIER=latrace-backup
RCLONE_INTERVALLE=900
